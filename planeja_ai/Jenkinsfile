pipeline {
    agent {
        docker {
            image 'ghcr.io/cirruslabs/flutter:stable'
            args '-u root --privileged'
        }
    }

    environment {
        FLUTTER_ROOT = '/opt/flutter'
        PUB_CACHE    = "${WORKSPACE}/.pub-cache"
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    stages {

        stage('🔧 Setup') {
            steps {
                dir('planeja_ai') {
                    echo 'Configurando ambiente Flutter...'
                    sh 'flutter --version'
                    sh 'flutter config --no-analytics'
                    sh 'flutter pub get'
                }
            }
        }

        stage('Analyze (Lint)') {
            steps {
                dir('planeja_ai') {
                    echo 'Executando análise estática do código...'
                    sh 'flutter analyze --no-pub'
                }
            }
            post {
                failure {
                    echo '❌ Falhas de lint encontradas!'
                }
            }
        }

        stage('Testes Unitários e de Widget') {
            steps {
                dir('planeja_ai') {
                    echo 'Executando testes...'
                    sh '''
                        flutter test \
                          --no-pub \
                          --reporter expanded \
                          --coverage
                    '''
                }
            }
            post {
                always {
                    publishCoverage(
                        adapters: [coberturaAdapter('planeja_ai/coverage/lcov.info')],
                        sourceFileResolver: sourceFiles('STORE_ALL_BUILD')
                    )
                }
            }
        }

        stage('Build Android (APK)') {
            //todas as branches
            steps {
                dir('planeja_ai') {
                    echo 'Gerando APK de release...'
                    sh 'flutter build apk --release --no-pub'
                }
            }
            post {
                success {
                    archiveArtifacts(
                        artifacts: 'planeja_ai/build/app/outputs/flutter-apk/*.apk',
                        fingerprint: true
                    )
                }
            }
        }

        stage('Build Web') {
            //todas as branches
            steps {
                dir('planeja_ai') {
                    echo 'Gerando build Web...'
                    sh 'flutter build web --release --no-pub'
                }
            }
            post {
                success {
                    archiveArtifacts(
                        artifacts: 'planeja_ai/build/web/**',
                        fingerprint: true
                    )
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline finalizado.'
            cleanWs()
        }
        success {
            echo '✅ Pipeline concluído com sucesso!'
        }
        failure {
            echo '❌ Pipeline falhou. Verifique os logs.'
        }
    }
}
